{
  "expo": {
    "name": "Monster Cheklist",
    "slug": "monster-technist",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "assets/clean-icon.png",
    "userInterfaceStyle": "dark",
    "newArchEnabled": false,
    "splash": {
      "image": "assets/clean-icon.png",
      "resizeMode": "cover",
      "backgroundColor": "#000000"
    },
    "assetBundlePatterns": [
      "**/*"
    ],
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.monster.technist"
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "assets/clean-icon.png",
        "backgroundColor": "#000000"
      },
      "package": "com.monster.technist",
      "permissions": [
        "CAMERA",
        "android.permission.CAMERA",
        "android.permission.RECORD_AUDIO",
        "CAMERA",
        "android.permission.CAMERA",
        "android.permission.RECORD_AUDIO"
      ]
    },
    "web": {
      "favicon": "assets/icon.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-camera",
        {
          "cameraPermission": "Autoriser l'application à utiliser la caméra pour scanner les canettes."
        }
      ],
      [
        "expo-build-properties",
        {
          "android": {
            "kotlinVersion": "1.9.25"
          }
        }
      ],
      "expo-asset",
      "expo-web-browser"
    ],
    "scheme": "monster-technist",
    "extra": {
      "router": {},
      "eas": {
        "projectId": "8610cfad-c5dd-4bd8-a30e-ca08c8f97d12"
      }
    },
    "runtimeVersion": "exposdk:54.0.0",
    "updates": {
      "url": "https://u.expo.dev/8610cfad-c5dd-4bd8-a30e-ca08c8f97d12"
    }
  }
}
